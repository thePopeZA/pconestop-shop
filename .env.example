# ============================================================
#  PC One Stop Shop — Environment configuration
#  Copy this file to `.env` and fill in real values.
#  NEVER commit .env to git.
# ============================================================

# local | production
APP_ENV=local
APP_NAME="PC One Stop"
APP_URL=http://localhost/pconestopshop
APP_DEBUG=true

# ---- Database ----
DB_HOST=localhost
DB_NAME=pconestop
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# ---- Pricing ----
# sell = feed_price * MARKUP_MULTIPLIER * VAT_MULTIPLIER
MARKUP_MULTIPLIER=1.25
VAT_MULTIPLIER=1.15
VAT_RATE=0.15

# ---- Shipping ----
SHIPPING_FLAT=99.00
SHIPPING_FREE_OVER=1000.00

# ---- Syntech feed ----
# Paste the direct download URLs from https://www.syntech.co.za/my-account/feeds/
SYNTECH_FEED_XML_FULL=
SYNTECH_FEED_XML_UPDATE=
SYNTECH_FEED_JSON_FULL=
SYNTECH_LOGIN_USER=shop@pconestop.co.za
SYNTECH_LOGIN_PASS=

# ---- Yoco ----
YOCO_PUBLIC_KEY=
YOCO_SECRET_KEY=
YOCO_WEBHOOK_SECRET=

# ---- Email (SMTP) ----
MAIL_ENABLED=false
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=orders@pconestop.co.za
MAIL_PASS=
MAIL_FROM=orders@pconestop.co.za
MAIL_FROM_NAME="PC One Stop Shop"
ORDER_NOTIFY_EMAIL=orders@pconestop.co.za

# ---- Admin ----
# Set these, then run /admin first-time setup to hash the password
ADMIN_SETUP_KEY=change-me-to-a-random-string
