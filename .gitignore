# Secrets & environment
.env
.env.*
!.env.example

# Storage (feeds, logs, cache)
/storage/feeds/*
/storage/logs/*
/storage/cache/*
!/storage/feeds/.gitkeep
!/storage/logs/.gitkeep
!/storage/cache/.gitkeep

# Dependencies
/vendor/

# OS / editor junk
.DS_Store
Thumbs.db
*.log
*.swp
.idea/
.vscode/

# Local uploads
/uploads/*
!/uploads/.gitkeep

# Promo packs are published server-side from the admin panel (not via git),
# so the images + frozen captions live only on the server.
/promo-82f02098/img/*
!/promo-82f02098/img/.gitkeep
/promo-82f02098/captions.json
